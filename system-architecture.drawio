        <mxCell id="edu_box" value="&lt;b&gt;EDUCATION&lt;/b&gt;&lt;br&gt;&lt;hr&gt;🔑 id : Integer (PK)&lt;br&gt;universityName : String&lt;br&gt;degree : String&lt;br&gt;major : String&lt;br&gt;startDate : String&lt;br&gt;endDate : String&lt;br&gt;description : Text" style="rounded=1;arcSize=4;whiteSpace=wrap;html=1;align=left;spacingLeft=10;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
