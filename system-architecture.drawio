        <mxCell id="resume_box" value="&lt;b&gt;RESUME&lt;/b&gt;&lt;br&gt;&lt;hr&gt;🔑 documentId : String (PK)&lt;br&gt;userEmail : String (FK)&lt;br&gt;title : String&lt;br&gt;firstName : String&lt;br&gt;lastName : String&lt;br&gt;jobTitle : String&lt;br&gt;email : String&lt;br&gt;phone : String&lt;br&gt;address : String&lt;br&gt;themeColor : String" style="rounded=1;arcSize=4;whiteSpace=wrap;html=1;align=left;spacingLeft=10;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
